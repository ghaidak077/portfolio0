# ─────────────────────────────────────────────────────────────
# Cloudflare Pages — _headers
# 2026 security standards · Lighthouse 100 compatible
# ─────────────────────────────────────────────────────────────

/*
  # HTTPS Strict Transport Security (2-year, preload-ready)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Clickjacking protection
  X-Frame-Options: DENY

  # MIME-type sniffing protection
  X-Content-Type-Options: nosniff

  # Referrer: send origin only on cross-origin HTTPS requests
  Referrer-Policy: strict-origin-when-cross-origin

  # Content Security Policy
  # unsafe-inline on script-src is required for:
  #   - document.documentElement.classList.remove('no-js') inline script
  #   - JSON-LD schema (type=application/ld+json)
  # To harden further: replace inline scripts with nonces.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://usebasin.com https://www.google-analytics.com https://region1.google-analytics.com https://analytics.google.com https://cloudflareinsights.com https://www.clarity.ms https://c.clarity.ms; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://usebasin.com; upgrade-insecure-requests;

  # Permissions Policy (2026 — removed deprecated interest-cohort/FLoC)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), autoplay=(), picture-in-picture=(), screen-wake-lock=(), web-share=()

  # Cross-Origin policies (required for SharedArrayBuffer / Spectre mitigation)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin

  # Hide server fingerprint
  X-Powered-By: none

  # Cache: HTML — always revalidate (cache-busted JS/CSS via ?v=)
  Cache-Control: public, max-age=0, must-revalidate

# ── Static assets: 1-year immutable (filename never changes) ──

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

# SVG favicons: 1 year (filename-stable)
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# logo.svg is referenced by name — long cache safe
/logo.svg
  Cache-Control: public, max-age=31536000, immutable

# ── JS/CSS: revalidate on every request (cache-busted via ?v=) ──

/*.css
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=0, must-revalidate

# ── Crawl/meta files: 24h cache ──

/sitemap.xml
  Cache-Control: public, max-age=86400, must-revalidate

/robots.txt
  Cache-Control: public, max-age=86400, must-revalidate

/site.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate
  Content-Type: application/manifest+json; charset=utf-8
